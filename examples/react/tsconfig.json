{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["vite/client"],
    "paths": {
      "@brand/*": ["./.runtime/brand/*"],
      "@brand-components/*": ["./.runtime/brand/components/*"],
      "@brand-router/*": ["./.runtime/brand/extra-router/*"],
      "@brand-assets/*": ["./.runtime/brand/assets/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
